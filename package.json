    "description": "",
    "scripts": {
        "dev": "concurrently -n front,backend,worker -c blue,green,yellow 'pnpm:dev:front' 'pnpm:dev:backend' 'pnpm:dev:worker'",
        "dev:front": "cd front && pnpm run dev",
        "dev:backend": "cd backend && air",
        "dev:worker": "cd worker && air",
